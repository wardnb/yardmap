# Supabase — create your project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Mapbox — get your token at https://mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token

# OpenAI (optional) — enables AI plant ID + health diagnosis
# Get at https://platform.openai.com — uses gpt-4o vision
NEXT_PUBLIC_OPENAI_KEY=sk-your-openai-key

# Supabase service role key (optional, server-side ops)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
